# npm dependencies — restored with `npm install`, never committed.
/node_modules/

# Vendored third-party libraries served directly by the page. These are large
# and reproducible; keeping them out of the repo avoids accidental vendoring
# commits and a bloated GitHub Pages artifact. (package-lock.json IS committed
# so the dependency set stays pinned.)
/three.js/
/vendor/

# Editor / IDE
/.vs/
/.idea/
*.swp
*~

# OS cruft
.DS_Store
Thumbs.db

# Logs
*.log
